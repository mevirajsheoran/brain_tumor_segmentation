# File: .gitignore

# ============================================================
# PYTHON
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyd
.Python

# ============================================================
# VIRTUAL ENVIRONMENTS
# ============================================================
tumor_env/
venv/
.venv/
env/
ENV/

# ============================================================
# PACKAGING / BUILD
# ============================================================
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# ============================================================
# TESTING
# ============================================================
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ============================================================
# TYPE CHECKING
# ============================================================
.mypy_cache/
.pyre/
.pytype/

# ============================================================
# JUPYTER
# ============================================================
.ipynb_checkpoints/

# ============================================================
# LOGS
# ============================================================
*.log
logs/

# ============================================================
# OS / EDITOR
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# ============================================================
# ENVIRONMENT / SECRETS
# ============================================================
.env
.env.*

# ============================================================
# DATA — Raw dataset is 4GB, NEVER upload
# Processed .npy files are 700MB, too large for GitHub
# ============================================================
data/raw/
data/processed/
data/interim/
data/external/

# ============================================================
# MEDICAL IMAGE FORMATS
# ============================================================
*.nii
*.nii.gz
*.mha
*.mhd
*.nrrd
*.dcm

# ============================================================
# NUMPY DATA FILES
# ============================================================
*.npy
*.npz
*.pkl

# ============================================================
# MODEL CHECKPOINTS — Too large for GitHub (120MB each)
# Upload to Google Drive and share links in README
# ============================================================
checkpoints/*.pth
checkpoints/*.pt
checkpoints/*.ckpt
checkpoints/*.h5
checkpoints/*.hdf5
checkpoints/*.onnx
checkpoints/*.tflite
checkpoints/unet/
checkpoints/attention_unet/

# Keep results_summary.json (small, useful)
!checkpoints/results_summary.json

# ============================================================
# ML TRACKING
# ============================================================
runs/
wandb/
mlruns/
lightning_logs/
tensorboard/

